{
    "name": "task-orbit",
    "version": "1.0.0",
    "description": "task management full-stack application",
    "homepage": "https://github.com/arpitjana2103/grow-10-task-orbit#readme",
    "bugs": {
        "url": "https://github.com/arpitjana2103/grow-10-task-orbit/issues"
    },
    "license": "ISC",
    "author": "Arpit Jana",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arpitjana2103/grow-10-task-orbit.git"
    },
    "type": "module",
    "main": "index.js",
    "scripts": {
        "start:dev": "cross-env NODE_ENV=development tsx watch --clear-screen=true src/index.ts",
        "start:dev-prod": "cross-env NODE_ENV=production tsx watch --clear-screen=true src/index.ts",
        "start:prod": "cross-env NODE_ENV=production node dist/index.js",
        "build": "rimraf dist && tsc",
        "typecheck": "tsc --noEmit",
        "typecheck:watch": "tsc --noEmit --watch",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "seed:role": "tsx src/seeder/role.seeder.ts"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-session": "^2.1.1",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "mongoose": "^9.3.2",
        "ms": "^2.1.3",
        "passport": "^0.7.0",
        "passport-google-oauth2": "^0.2.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "qs": "^6.15.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-session": "^2.0.49",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "@types/ms": "^2.1.0",
        "@types/node": "^25.5.0",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth2": "^0.1.10",
        "copyfiles": "^2.4.1",
        "cross-env": "^10.1.0",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
